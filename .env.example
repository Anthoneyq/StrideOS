# Public browser values. These are safe to expose when RLS policies are correct.
STRIDE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
STRIDE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server/CI only. Never put this in index.html or any browser-delivered file.
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_ACCESS_TOKEN
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
